# runtime
MYSQL_PASSWORD=your_password

REDIS_PASSWORD=

# RabbitMQ and order timeout
RABBITMQ_URL=amqp://order_app:order_dev_password@127.0.0.1:5672/
RABBITMQ_USER=order_app
RABBITMQ_PASSWORD=order_dev_password
ORDER_TIMEOUT_DELAY=30m

# JWT
JWT_SECRET=replace_with_a_32_plus_chars_random_secret

# assistant (mock does not call external services)
ASSISTANT_TIMEOUT=4s
LLM_MODE=mock
LLM_PROVIDER=mock
LLM_ENDPOINT=
LLM_MODEL=
LLM_API_KEY=
LLM_MAX_RESPONSE_BYTES=1048576

# DeepSeek V4 Flash (copy these values to .env and use a newly created key)
# LLM_MODE=chat_completions
# LLM_PROVIDER=deepseek
# LLM_ENDPOINT=https://api.deepseek.com/chat/completions
# LLM_MODEL=deepseek-v4-flash
# LLM_API_KEY=replace_with_your_deepseek_api_key

# test
MYSQL_TEST_PASSWORD=your_password
MYSQL_TEST_DATABASE=go_order_management_system_test
RUN_RABBITMQ_TEST=0
