# runtime
MYSQL_PASSWORD=your_password

REDIS_PASSWORD=

# RabbitMQ and order timeout
RABBITMQ_URL=amqp://order_app:order_dev_password@127.0.0.1:5672/
RABBITMQ_USER=order_app
