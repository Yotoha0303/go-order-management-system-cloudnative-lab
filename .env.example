# JWT
JWT_SECRET=replace_with_a_32_plus_chars_random_secret

# test
MYSQL_TEST_PASSWORD=your_password
MYSQL_TEST_DATABASE=go_order_management_system_test
RUN_RABBITMQ_TEST=0
