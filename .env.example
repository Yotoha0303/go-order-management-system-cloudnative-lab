# Shared runtime secrets
MYSQL_PASSWORD=your_password
JWT_SECRET=replace_with_a_32_plus_chars_random_secret
INTERNAL_SERVICE_TOKEN=replace_with_a_long_random_internal_service_token

# Logical database ownership
IDENTITY_DB_NAME=go_order_identity
CATALOG_DB_NAME=go_order_catalog
INVENTORY_DB_NAME=go_order_inventory
ORDER_DB_NAME=go_order_ordering

# Synchronous HTTP resilience
HTTP_CIRCUIT_FAILURE_THRESHOLD=5
HTTP_CIRCUIT_OPEN_INTERVAL=5s
HTTP_CIRCUIT_HALF_OPEN_MAX_PROBES=1

# Gateway token-bucket rate limiting
GATEWAY_RATE_LIMIT_PER_CLIENT_RPS=50
GATEWAY_RATE_LIMIT_PER_CLIENT_BURST=100
GATEWAY_RATE_LIMIT_GLOBAL_RPS=500
GATEWAY_RATE_LIMIT_GLOBAL_BURST=1000
GATEWAY_RATE_LIMIT_MAX_CLIENTS=10000
GATEWAY_RATE_LIMIT_INACTIVE_TTL=10m
GATEWAY_RATE_LIMIT_CLEANUP_INTERVAL=1m

# RabbitMQ and order timeout
RABBITMQ_USER=order_app
RABBITMQ_PASSWORD=order_dev_password
RABBITMQ_PUBLISH_CONFIRM_TIMEOUT=5s
ORDER_TIMEOUT_DELAY=30m
OUTBOX_LEASE_DURATION=30s

# Optional host ports
GATEWAY_HOST_PORT=8082
MYSQL_HOST_PORT=3306
RABBITMQ_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HOST_PORT=15672

# Integration tests
MYSQL_TEST_PASSWORD=your_password
MYSQL_TEST_DATABASE=go_order_management_system_test
RUN_RABBITMQ_TEST=0
